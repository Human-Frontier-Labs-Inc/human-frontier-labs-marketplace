{
  "title": "EXAMPLE C · 555 astable — blink one LED",
  "width": 1200, "height": 760, "routing": "ortho",
  "components": [
    { "type": "bus", "id": "v5",  "x1": 180, "x2": 1140, "y": 110, "label": "5V",  "color": "red" },
    { "type": "bus", "id": "gnd", "x1": 180, "x2": 1140, "y": 660, "label": "GND", "color": "black" },
    { "id": "power", "part": "power", "x": 40, "y": 300, "label": "5V in", "labelpos": "bottom" },
    { "id": "u1", "part": "ne555", "x": 460, "y": 320 },
    { "id": "r1", "part": "resistor", "x": 500, "y": 170, "rotate": 90, "label": "10k", "labelpos": "left" },
    { "id": "r2", "part": "resistor", "x": 300, "y": 200, "label": "47k", "labelpos": "top" },
    { "id": "c1", "part": "ecap", "x": 600, "y": 560, "label": "10µF", "labelpos": "right" },
    { "id": "rl", "part": "resistor", "x": 830, "y": 400, "label": "330Ω", "labelpos": "top" },
    { "id": "d1", "part": "led", "x": 1000, "y": 430 }
  ],
  "wires": [
    { "from": ["power", "5.0V"], "to": ["v5"],  "color": "red" },
    { "from": ["power", "GND"],  "to": ["gnd"], "color": "black" },
    { "from": ["u1", "Vcc Supply Voltage"], "to": ["v5"],  "color": "red" },
    { "from": ["u1", "Reset"],              "to": ["v5"],  "color": "red" },
    { "from": ["u1", "Ground"],             "to": ["gnd"], "color": "black" },
    { "from": ["r1", "Pin 0"], "to": ["v5"],           "color": "red" },
    { "from": ["r1", "Pin 1"], "to": ["u1", "Discharge"], "color": "green" },
    { "from": ["r2", "Pin 0"], "to": ["u1", "Discharge"], "color": "green" },
    { "from": ["r2", "Pin 1"], "to": ["u1", "Threshold"], "color": "green" },
    { "from": ["u1", "Threshold"], "to": ["u1", "Trigger"], "color": "green" },
    { "from": ["c1", "+"], "to": ["u1", "Threshold"], "color": "green" },
    { "from": ["c1", "-"], "to": ["gnd"],             "color": "black" },
    { "from": ["u1", "Output"], "to": ["rl", "Pin 0"], "color": "blue" },
    { "from": ["rl", "Pin 1"], "to": ["d1", "anode"],  "color": "orange" },
    { "from": ["d1", "cathode"], "to": ["gnd"],        "color": "black" }
  ]
}
