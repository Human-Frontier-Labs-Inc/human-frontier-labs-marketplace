    { "type": "bus", "id": "gnd", "x1": 180, "x2": 940, "y": 470, "label": "GND", "color": "black" },
    { "id": "power", "part": "power", "x": 40, "y": 220, "label": "5V in", "labelpos": "bottom" },
    { "id": "pot", "part": "pot", "x": 380, "y": 170, "label": "10k dim" },
    { "id": "r1", "part": "resistor", "x": 560, "y": 260, "label": "220Ω", "labelpos": "top" },
    { "id": "d1", "part": "led", "x": 760, "y": 250 }
  ],
  "wires": [
    { "from": ["power", "5.0V"], "to": ["v5"],  "color": "red" },
