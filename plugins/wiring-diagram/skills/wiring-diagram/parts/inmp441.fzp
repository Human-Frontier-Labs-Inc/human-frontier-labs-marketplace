 <author>Graham Coulby</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'MS Shell Dlg 2'; font-size:8.25pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">This is a simple breakout board for the INMP441 I2S MEMS microphone.&lt;/p>&lt;/body>&lt;/html></description>
 <title>INMP441</title>
 <url>https://invensense.tdk.com/wp-content/uploads/2015/02/INMP441.pdf</url>
 <tags>
  <tag>i2s</tag>
  <tag>mems</tag>
  <tag>microphone</tag>
 </tags>
 <properties>
  <property name="family">i2s</property>
  <property name="variant">variant 1</property>
  <property name="SNR">61 dBA</property>
  <property name="Dynamic Range">87 dB</property>
  <property name="High Frequency -3 dB Point">15 kHz</property>
  <property name="Sensitivity">-26 dBFS</property>
  <property name="Voltage">3.3v</property>
  <property name="Low Frequency -3 dB Point">60 Hz</property>
  <property name="Noise Floor">-87 dBFS</property>
  <property name="layer"></property>
  <property name="Maximum Acoustic Input">120</property>
  <property name="part number"></property>
 </properties>
 <views>
